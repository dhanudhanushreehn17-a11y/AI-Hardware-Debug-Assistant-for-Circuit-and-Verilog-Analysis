# Configuration for AI Hardware Debug Assistant
# Copy this file to .env and modify as needed

# OpenCode Server URL
OPENCODE_API_URL=http://localhost:8080

# AI Models
# For circuit image analysis (vision model)
CIRCUIT_MODEL=llava

# For Verilog code analysis
VERILOG_MODEL=codellama

# Alternative models you can use:
# CIRCUIT_MODEL=bakllava
# VERILOG_MODEL=llama3
# VERILOG_MODEL=mistral
